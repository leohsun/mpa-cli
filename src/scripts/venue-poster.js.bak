let province = '全国'

const minutesEl = document.querySelector('#js-minutes')
const secondsEl = document.querySelector('#js-seconds')
const dateEl = document.querySelector('#js-date')


function getProvinceFromAmap(lnglat) {
  AMap.plugin('AMap.Geolocation', function () {
    var geolocation = new AMap.Geolocation({
      // 是否使用高精度定位，默认：true
      enableHighAccuracy: true,
      // 设置定位超时时间，默认：无穷大
      timeout: 10000,
      // 定位按钮的停靠位置的偏移量，默认：Pixel(10, 20)
      buttonOffset: new AMap.Pixel(10, 20),
      //  定位成功后调整地图视野范围使定位位置及精度范围视野内可见，默认：false
      zoomToAccuracy: true,
      //  定位按钮的排放位置,  RB表示右下
      buttonPosition: 'RB'
    })

    geolocation.getCurrentPosition()
    AMap.event.addListener(geolocation, 'complete', onComplete)
    AMap.event.addListener(geolocation, 'error', onError)

    function onComplete({ addressComponent }) {
      // data是具体的定位信息
      province = addressComponent.province.replace(/省/, '')
      document.querySelector('#js-location').innerText = province
    }

    function onError(data) {
      // 定位出错
      console.log('error-->', data)
      document.querySelector('#js-location').innerText = province
    }
  })
}

function generateList(dom, data, unshift = false) {
  const fragment = new DocumentFragment()
  data.forEach(data => {
    const liEl = document.createElement('li')
    liEl.className = 'venue-poster__list-item  venue-poster__gird-03'
    for (let key in data) {
      if (data.hasOwnProperty(key)) {
        const spanEl = document.createElement('span')
        spanEl.innerText = data[key]
        liEl.appendChild(spanEl)
      }
      fragment.appendChild(liEl)
    }

    if (unshift) dom.insertBefore(fragment, dom.firstChild)
    else dom.appendChild(fragment)

  })


}

function updateTimeView(rawSeconds) {
  const minutes = parseInt(rawSeconds / 60)
  const seconds = rawSeconds % 60
  minutesEl.innerText = minutes
  secondsEl.innerText = seconds
}

function timeCountDown(minutes = 40) {
  const totalSeconds = minutes * 60
  let currentSeconds = totalSeconds
  clearInterval(window.timer)
  window.timer = setInterval(() => {
    currentSeconds--
    updateTimeView(currentSeconds)
    if (currentSeconds == 0) return clearInterval(window.timer)
  }, 1000)
}

function fillZero(num) {
  return num > 9 ? num : '0' + num
}

function getDate() {
  const date = new Date()
  const year = date.getFullYear()
  const month = date.getMonth() + 1
  const day = date.getDate()
  dateEl.innerText = `${year}年${fillZero(month)}月${fillZero(day)}`
}



// step 01 get province
getProvinceFromAmap()

getDate()

// step 02 count down time
timeCountDown()


document.querySelector('#js-audio').play()


//  action submit by user
generateList(document.querySelector('#js-list-all'), dataExist)

const submitBtn = document.querySelector('#js-submit')

submitBtn.onclick = function () {
  const merchantEl = document.querySelector('#js-merchant')
  const ownerEl = document.querySelector('#js-owner')
  const merchant = merchantEl.value
  const owner = ownerEl.value
  if (!merchant || !owner) return
  const description = `已由${province}分会场、保护5分钟`
  const data = [{ merchant, owner, description }]
  generateList(document.querySelector('#js-list-current'), data, true)
  merchantEl.value = ownerEl.value = ''
}

// action edit by user

document.body.onclick = function (e) {
  const tar = e.target
  if (tar.classList.contains('venue-poster__editable')) {
    const inputEl = document.createElement('input')
    inputEl.className = 'venue-poster__editor'
    const curText = tar.innerText
    inputEl.style.width = curText.length + 'em'
    inputEl.value = curText

    tar.innerHTML = ''
    tar.appendChild(inputEl)
    inputEl.focus()
    inputEl.onblur = function () {
      tar.innerText = this.value
    }

    inputEl.oninput = function (e) {
      const _width = this.value.length > 0 ? this.value.length : curText.length
      this.style.width = _width + 'em'
    }
  }
}