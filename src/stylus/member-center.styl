@import './reset'
@import './layout'

.m-c
  position relative
  // background-color #F9F9F9
  min-height 100vh
  color #333333
  padding 0 23px
  border-box()

  &__header
    ffc-row(flex-start)

  &__merchant-logo
    width 30px
    height 30px
    margin-right 12px

  &__merchant-name
    font-size 14px
    line-height 54px

  &__card
    width 100%
    border-radius 10px
    margin 20px 0
    overflow hidden
    background-color #fefefe
    box-shadow 2px 2px 24px -6px #8A8A8A
    background-size 100% auto
    background-repeat no-repeat
    background-position center top
    bounce()

  &-card
    &__name
      font-size 16px
      color #ffffff
      padding 19px 22px
      height 62px
      border-box()

    &__content
      position relative
      background-color #fff
      text-center()
      height 138px
      // padding-top 50px
      border-box()

    &__nickname
      font-size 16px
      line-height 16px
      margin 16px 0 24px

    &__avatar
      position absolute
      left 50%
      transform translateX(-50%)
      width 63px
      height 71px
      top -30px

      &-img
        width 56px
        height 56px
        circle()
        border 4px solid #ffffff
        box-shadow 0 0 5px 0 rgba(0, 0, 0, 0.2)

      &-vip-mark
        position absolute
        left 0
        bottom 0
        width 100%
        height 21px

    &__info
      ffc-row()

      &-item
        flex 1
        text-center()

    &__title
      font-size 20px
      color #666666
      line-height 40px
      height 40px
      margin-bottom 6px

    &__val
      font-size 14px
      height 34px
      line-height 34px

  &__coupons
    height 90px
    white-space nowrap

  &__coupon
    margin-bottom 20px
    background-color #fff4d6
    padding 20px 30px
    border-radius 12px
    display inline-block
    margin-right 10px

    &-money
      font-size 12px
      width 70px
      color #888888
      ffc-col(space-between, flex-start)

      text
        flex 1

        &:first-child
          color #E02020
          font-size 16px
          margin-bottom 10px

    &-title
      font-size 14px
      color #333333

    &-radio
      border none

    &-container
      position relative
      border 1px solid #ffffff
      height 65px
      ffc-row(space-between)
      justify-items flex-start
      background-color #fff4d6
      padding 10px 13px
      width 100%
      border-box()
