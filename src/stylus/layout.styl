ffc-col(main = space-around, cross = center)
  display flex
  flex-direction column
  justify-content main
  align-items cross

ffc-row(main = space-around, cross = center)
  display flex
  justify-content main
  align-items cross

text-center()
  text-align center

border-box()
  box-sizing border-box

button-effect()
  transform scale(1)
  transition all 0.2s

  &:active
    transform scale(0.99)

circle()
  border-radius 50%
