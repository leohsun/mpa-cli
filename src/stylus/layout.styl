ffc-col(main = space-around, cross = center)
  display flex
  flex-direction column
  justify-content main
  align-items cross

ffc-row(main = space-around, cross = center)
  display flex
  justify-content main
  align-items cross

text-center()
  text-align center

border-box()
  box-sizing border-box

button-effect()
  transform scale(1)
  transition all 0.2s

  &:active
    transform scale(0.99)

circle()
  border-radius 50%

text-ellipsis(row = 1)
  if (row == 1)
    overflow hidden
    white-space nowrap
    text-overflow ellipsis
  else
    display -webkit-box
    -webkit-box-orient vertical
    -webkit-line-clamp row
    height unit(row, 'em')
    overflow hidden
