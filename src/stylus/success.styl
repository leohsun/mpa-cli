@import './reset'

.success
  &__header
    height 55.4667vw
    background url('../images/success_bg.png') no-repeat
    background-size cover
    margin-bottom 9.0667vw

  &__content
    text-center()
    margin-bottom 12vw

    img
      width 12.8vw
      height auto
      margin-bottom 4.8vw

    h2
      font-size 16px
      line-height 1.4

    h1
      font-size 36px
      line-height 48px

  &__list
    padding 0 10.1333vw

    &-item
      color #999999
      font-size 14px
      height 9.3333vw
      line-height 9.3333vw
      border-bottom 1px solid #F4F4F4

      span
        float right
        display inline-block
        height 9.3333vw
        line-height 9.3333vw