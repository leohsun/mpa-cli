@import './reset'

// @import './layout'
.tutor
  font-size 14px
  color #616264
  padding 6vw 4vw
  box-sizing border-box

  h1, h2
    font-size 18px
    line-height 1.2
    font-weight bold
    color #000000
    text-align center
    margin-bottom 4vw

  h2
    font-size 16px
    text-align left

  img
    display block
    width 100%
    height auto
    margin-bottom 5vw

  p
    margin-bottom 5vw
    line-height 1.5

  strong
    font-weight bold